<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.projectkronos.daily-briefing</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>__KRONOS_ROOT__/launchd/run-daily-briefing.sh</string>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>ProcessType</key>
  <string>Background</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>__KRONOS_HOME__</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>__KRONOS_ROOT__/daily-briefing.log</string>

  <key>StandardErrorPath</key>
  <string>__KRONOS_ROOT__/daily-briefing.log</string>
</dict>
</plist>
